# App
APP_ENV=development
SECRET_KEY=                              # python -c "import secrets; print(secrets.token_urlsafe(48))"
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database / Redis
DATABASE_URL=postgresql+psycopg2://cpmai:cpmai_dev@postgres:5432/cpmai_prep
REDIS_URL=redis://redis:6379/0

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Encryption (Fernet 32-byte urlsafe-base64)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Bootstrap super-admin (created on first run if no super_admin exists).
# After install, rotate this password via /admin/users → Reset password.
# Stale BOOTSTRAP_ADMIN_PASSWORD is harmless — it's only consulted on the
# first install when no super_admin yet exists.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=

# Smoke / CI test super-admin — kept INTENTIONALLY separate from the
# operator account above so rotating BOOTSTRAP_ADMIN_PASSWORD via the UI
# never breaks scripts/smoke_admin_crud.py. The seeder keeps the DB row's
# password in sync with whatever's set here, so the smoke is always able
# to log in. Generated automatically on first install.
SMOKE_ADMIN_EMAIL=
SMOKE_ADMIN_PASSWORD=

# AI Assistant — bootstrap defaults only.
# All operational limits live in system_settings (runtime-editable).
ASSISTANT_FALLBACK_PROVIDER=stub

# Google OAuth — get one at https://console.cloud.google.com/apis/credentials
# (web application client). See docs/google-auth-setup.md.
# Leave empty to disable Google sign-in (returns 503 for /auth/google).
GOOGLE_OAUTH_CLIENT_ID=
# Optional: comma-separated additional accepted audiences (mobile clients).
GOOGLE_OAUTH_ALLOWED_CLIENT_IDS=
