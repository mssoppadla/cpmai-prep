# Keep the Docker build context small. frontend/Dockerfile.prod runs its own
# `npm ci` and `next build` inside the image, so none of these belong in the
# context — shipping them makes `docker build` (and scripts/preflight.sh on
# Windows) transfer ~900MB and crawl.
node_modules
.next
.git
.gitignore
npm-debug.log*
yarn-debug.log*
yarn-error.log*
coverage
.env*.local
.DS_Store
Dockerfile*
.dockerignore
