backend/tests/unit/geoip/fixtures/test-City.mmdb

# Admin file uploads (images, videos, attached PDFs etc.) — runtime
# data only, never source-controlled. Prod stores them in a docker
# volume; local dev creates the dir on first upload.
backend/uploads/
