# Force LF line endings for files that run on Linux containers / VPS.
# Without this, Windows checkouts CRLF the files and they break when
# bash, docker, or Caddy tries to parse them.
*.sh                text eol=lf
*.py                text eol=lf
*.yml               text eol=lf
*.yaml              text eol=lf
Dockerfile          text eol=lf
Dockerfile.*        text eol=lf
Caddyfile           text eol=lf
.env.example        text eol=lf
*.sql               text eol=lf
*.conf              text eol=lf
